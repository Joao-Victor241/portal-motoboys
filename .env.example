# Modelo de configuração — copie para um arquivo chamado .env e preencha.
# NUNCA coloque segredos reais neste .env.example (ele vai pro Git).

# --- DMP Access II (reconhecimento facial - Dimep) ---
DMP_BASE_URL=https://dmpaccess.dimep-ams.com.br/itk
DMP_USERNAME=SEU_USUARIO
DMP_PASSWORD=SUA_SENHA
DMP_CHAVE_ACESSO=SUA_CHAVE
DMP_NAK=SEU_TOKEN_NAK

# false = cadastra de verdade no DMP; true = modo simulado (não escreve no DMP)
DMP_SIMULADO=true

# IDs da conta no DMP (ajuste conforme o ambiente)
DMP_ORG_STRUCTURE=398
DMP_ACCESS_PROFILE=47
DMP_SITU_PERMITIDO=10
DMP_SITU_BLOQUEADO=11

# --- ERP SIAC (quando a API estiver disponível) ---
SIAC_BASE_URL=
SIAC_TOKEN=

# --- Leitura da CNH por IA (visão do Claude) ---
ANTHROPIC_API_KEY=

# --- Banco de dados PostgreSQL (produção) ---
DATABASE_URL=

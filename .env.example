# ============================================================================
# MODELO de variáveis de ambiente do Portal de Motoboys.
#
# COMO USAR:
#   1. Copie este arquivo para um novo chamado ".env" (sem o .example).
#   2. Preencha os valores reais (peça as credenciais a quem administra).
#   3. NUNCA versione o .env (ele está no .gitignore) — segredos só aqui, local.
#
# No Streamlit Cloud, estes mesmos nomes vão em "Settings → Secrets"
# (não se usa arquivo .env na nuvem).
# ============================================================================

# ---- Banco de dados (PostgreSQL / Neon) ------------------------------------
# Sem DATABASE_URL o app cai no SQLite local (dados somem a cada reinício).
DATABASE_URL=postgresql://usuario:senha@host:5432/banco?sslmode=require
DB_SCHEMA=motoboys_portal

# ---- Integração DMP Access II (Dimep / catraca facial) ---------------------
# DMP_SIMULADO=true  -> não chama a API real (modo de teste)
# DMP_SIMULADO=false -> integra de verdade (precisa das credenciais abaixo)
DMP_SIMULADO=true
DMP_BASE_URL=https://dmpaccess.dimep-ams.com.br/itk
DMP_USERNAME=
DMP_PASSWORD=
DMP_NAK=
DMP_NAK_ACCESSLOG=
# IDs da configuração do DMP (valores padrão do ambiente atual)
DMP_ORG_STRUCTURE=398
DMP_ACCESS_PROFILE=47
DMP_SITU_PERMITIDO=10
DMP_SITU_BLOQUEADO=11

# ---- IA para leitura da CNH (preencher cadastro pela foto) ------------------
# Chave da API da Anthropic (Claude). Sem ela, o "ler CNH" não funciona.
ANTHROPIC_API_KEY=

# ---- URL pública do portal (usada no link da selfie / WhatsApp) ------------
# Em produção, a URL do app no Streamlit Cloud (ex.: https://motoboys-kaizen.streamlit.app)
PORTAL_BASE_URL=http://localhost:8501

# ---- Senhas dos perfis (bcrypt é gerado a partir destes valores) -----------
# Se não definir, o app usa senhas padrão de teste (admin123, ol123, etc.).
# Em produção, defina senhas fortes.
ADMIN_PASSWORD=
OL_EXEMPLO_PASSWORD=
OPERADOR_PASSWORD=
CONFERENCIA_PASSWORD=
FINANCEIRO_PASSWORD=

# MODELO de segredos para o Streamlit Cloud.
# NÃO preencha valores reais aqui (este arquivo vai para o Git).
#
# No Streamlit Cloud: App → Settings → Secrets → cole o conteúdo abaixo
# (já com os valores reais). O secrets.toml REAL nunca é versionado.

# --- DMP Access II (reconhecimento facial - Dimep) ---
DMP_BASE_URL = "https://dmpaccess.dimep-ams.com.br/itk"
DMP_USERNAME = "VOGA PARK"
DMP_PASSWORD = "COLE_A_SENHA_AQUI"
DMP_NAK = "COLE_O_TOKEN_NAK_AQUI"
DMP_SIMULADO = "false"

DMP_ORG_STRUCTURE = "398"
DMP_ACCESS_PROFILE = "47"
DMP_SITU_PERMITIDO = "10"
DMP_SITU_BLOQUEADO = "11"

# URL pública do próprio app (para os links de selfie apontarem certo).
# Troque pelo endereço final, ex.: https://motoboys-kaizen.streamlit.app
PORTAL_BASE_URL = "https://motoboys-kaizen.streamlit.app"

# --- Senhas dos usuários do portal (troque por senhas FORTES) ---
ADMIN_PASSWORD = "TROQUE_POR_UMA_SENHA_FORTE"
OL_EXEMPLO_PASSWORD = "TROQUE_POR_UMA_SENHA_FORTE"
OPERADOR_PASSWORD = "TROQUE_POR_UMA_SENHA_FORTE"

# --- Leitura da CNH por IA (opcional) ---
ANTHROPIC_API_KEY = ""

# --- PostgreSQL (produção — quando a TI liberar) ---
# Com DATABASE_URL preenchida, o portal passa a SALVAR no PostgreSQL (persistente).
# Sem ela, usa SQLite local temporário. Inclua sslmode=require se o banco exigir SSL.
# Ex.: postgresql://usuario:senha@host:5432/banco?sslmode=require
DATABASE_URL = ""
# Schema onde o portal cria as tabelas (padrão motoboys_portal).
DB_SCHEMA = "motoboys_portal"
